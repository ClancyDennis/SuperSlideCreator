AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-realtime
AZURE_OPENAI_API_VERSION=2024-10-01-preview
AZURE_OPENAI_API_KEY=

# Slide-building worker (separate deployment — chat-completions, not realtime)
SLIDE_AZURE_OPENAI_DEPLOYMENT=gpt-5.4
SLIDE_AZURE_OPENAI_API_VERSION=2024-10-21

# Image generation (same resource, images/generations API)
IMAGE_AZURE_OPENAI_DEPLOYMENT=gpt-image-2
IMAGE_AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Voice agent config
REALTIME_VOICE=alloy
REALTIME_INSTRUCTIONS=You are a friendly voice assistant that helps build slide decks.

# Realtime-2 only. One of: minimal, low, medium, high. Leave empty for v1 deployments.
REALTIME_REASONING_EFFORT=

# Logging
LOG_LEVEL=INFO
